<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pushplus_token_label"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/pushplus_token_hint"
                android:inputType="text" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pushplus_topic_label"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_topic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/pushplus_topic_hint"
                android:inputType="text" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pushplus_channel_label"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_channel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/pushplus_channel_hint"
                android:inputType="text" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pushplus_template_label"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_template"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/pushplus_template_hint"
                android:inputType="text" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/template_help"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_template_label"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_title_template"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/title_template_hint"
                android:inputType="text" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/content_template_label"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_content_template"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/content_template_hint"
                android:inputType="textMultiLine"
                android:lines="3"
                android:gravity="top" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/save_config" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/service_status_stopped"
                android:textSize="16sp" />

            <Switch
                android:id="@+id/switch_service"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/enable_service"
                android:checked="false" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <Button
                android:id="@+id/btn_test"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/test_push" />

            <Button
                android:id="@+id/btn_battery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/request_battery_opt" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/last_log" />

            <TextView
                android:id="@+id/tv_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#EEEEEE"
                android:padding="8dp"
                android:text="No logs yet..."
                android:typeface="monospace" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
